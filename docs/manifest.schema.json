{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://calunga.dev/npm-registry/manifest.schema.json",
  "title": "npm Trusted Libraries onboarding manifest",
  "type": "object",
  "required": [
    "name",
    "version",
    "native_tier",
    "source",
    "entrypoint",
    "smoke",
    "outputs"
  ],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "native_tier": { "type": "string", "enum": ["A", "B", "C"] },
    "source": {
      "type": "object",
      "required": ["url", "ref"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "ref": { "type": "string", "minLength": 1 },
        "ref_type": { "type": "string" }
      },
      "additionalProperties": true
    },
    "upstream_npm": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "integrity": { "type": "string" }
      },
      "additionalProperties": true
    },
    "entrypoint": { "type": "string", "minLength": 1 },
    "smoke": { "type": "string", "minLength": 1 },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "path", "pulp_name"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["npm-package", "tl-platform-package"] },
          "path": { "type": "string" },
          "pulp_name": { "type": "string" },
          "platform": { "type": "string" },
          "libc": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "optional_dependencies_published": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requires_tl_packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
